# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/bloc_crm

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Google Sheets (pure Node.js polling — no n8n/Zapier) ────────────────────
# Sheet ID from URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEETS_ID=your_sheet_id_here

# Service account email (share the Sheet with this email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Private key from the service account JSON (keep the \n escapes)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# How often to poll Google Sheets (ms). 30000 = 30 seconds
SHEETS_POLL_INTERVAL_MS=30000
